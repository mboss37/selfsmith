# metric-contract.env — config for tools/metric-contract.sh (INSTANTIATE.md Step 0).
# Both commands run from the loop root and must print a bare number as their LAST line.

# The metric for a variant you KNOW is good (your champion / current configuration).
METRIC_GOOD_CMD='{{METRIC_GOOD_CMD}}'

# The metric for a PLANTED-BAD control you know is worse (a broken config, the baseline,
# a deliberately wrong variant). If you cannot name one, you do not yet have a metric.
METRIC_BAD_CMD='{{METRIC_BAD_CMD}}'

# 'higher' or 'lower' — which direction of the number is better.
METRIC_DIRECTION='higher'
