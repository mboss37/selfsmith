# metric-contract.env: config for tools/metric-contract.sh (INSTANTIATE.md Step 0).
# Both commands run from the loop root and must print a bare number as their LAST line.

# Known-good: the converged champion's mean effective latency on train (~332ms).
METRIC_GOOD_CMD='python3 sim/run_eval.py --window train --override timeout_ms=2000 --override retries=2 --override backoff_ms=0 | tail -n1 | python3 -c "import sys, json; print(json.load(sys.stdin)[\"mean_effective_ms\"])"'

# Planted-bad: a 60ms timeout fails nearly every request; with errors costed at +10s the
# metric MUST score it catastrophically worse. (This is also the reward-hack regression
# test: on raw success-only percentiles this config would look GOOD.)
METRIC_BAD_CMD='python3 sim/run_eval.py --window train --override timeout_ms=60 --override retries=0 --override backoff_ms=0 | tail -n1 | python3 -c "import sys, json; print(json.load(sys.stdin)[\"mean_effective_ms\"])"'

# Effective latency: lower is better.
METRIC_DIRECTION='lower'
